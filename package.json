{
  "name": "poe2-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping PathOfBuilding-PoE2 for build evaluation",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --include 'lua/**/*.lua' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "update-pob": "tsx scripts/update-pob.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:lua": "luajit scripts/ga-toy-test.lua",
    "test:gem": "luajit scripts/gem-toy-test.lua",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "build:web": "tsc -p src/web/tsconfig.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p src/web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/react": "^16.1.0",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "1.0.0",
    "husky": "9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "17.0.5",
    "prettier": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
